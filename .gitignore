# Dependencies
node_modules/

# Build output
dist/

# Astro cache
.astro/

# Environment variables
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Raw client photos — never commit these
COMPANY-PHOTOS/**/*
!COMPANY-PHOTOS/**/.gitkeep

# Processed images — generated at setup time
src/assets/images/**/*
!src/assets/images/**/.gitkeep

# Favicon — generated by script
public/favicon.png

# Skills — .agents/skills/ is tracked intentionally so every new project has skills ready from clone
# Agent-specific symlink folders created by the skills CLI — not needed in the repo
.claude/
.kiro/
.windsurf/
